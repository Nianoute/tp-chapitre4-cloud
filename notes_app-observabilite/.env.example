LOG_LEVEL=info          # Niveau de log (debug, info, warn, error)
PORT=3000              # Port de l'API
DB_HOST=db             # Host PostgreSQL
DB_PORT=5432           # Port PostgreSQL
DB_NAME=notes_app      # Nom de la base de données
DB_USER=postgres       # Utilisateur PostgreSQL
DB_PASSWORD=secret    # Mot de passe PostgreSQL
POSTGRES_PASSWORD=secret # Mot de passe pour l'utilisateur PostgreSQL
POSTGRES_USER=postgres # Nom d'utilisateur pour PostgreSQL
POSTGRES_DB=notes_app # Nom de la base de données à créer dans PostgreSQL